{
  "comments": {
    "blockComment": ["{#", "#}"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["<", ">"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] },
    { "open": "{%", "close": "%}", "notIn": ["string", "comment"] },
    { "open": "{{", "close": "}}", "notIn": ["string", "comment"] },
    { "open": "{#", "close": "#}", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*{%\\s*(block|if|for|match|while|cache|spaceless|autoescape|raw|capture|macro)\\b",
      "end": "^\\s*{%\\s*end\\b"
    }
  }
}
